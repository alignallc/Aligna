<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Você Viralizou. E Agora? — Aligna O.S.</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&family=DM+Sans:wght@300;400;500;600&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --gold: #C9913A;
    --gold-light: #E8B96A;
    --gold-pale: #F5DFA8;
    --sand: #F2E8D5;
    --sand-dark: #E6D4B0;
    --terra: #8B5E3C;
    --terra-dark: #5C3A1E;
    --ocean: #2C4A6E;
    --ocean-light: #4A7FA5;
    --ink: #1A1208;
    --cream: #FDF8F0;
    --white: #FFFFFF;
    --smoke: #F9F5EE;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--ink);
    overflow-x: hidden;
  }

  /* ── COVER ── */
  .cover {
    min-height: 100vh;
    background: var(--terra-dark);
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 0;
    overflow: hidden;
  }

  .cover-texture {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 20% 30%, rgba(201,145,58,0.25) 0%, transparent 60%),
      radial-gradient(ellipse at 80% 70%, rgba(44,74,110,0.2) 0%, transparent 50%),
      repeating-linear-gradient(
        45deg,
        transparent,
        transparent 40px,
        rgba(255,255,255,0.01) 40px,
        rgba(255,255,255,0.01) 41px
      );
  }

  .cover-grain {
    position: absolute;
    inset: 0;
    opacity: 0.04;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  }

  .cover-number {
    position: absolute;
    top: 48px;
    right: 48px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.2em;
    color: rgba(245,223,168,0.4);
    text-transform: uppercase;
  }

  .cover-badge {
    position: absolute;
    top: 48px;
    left: 48px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.25em;
    color: var(--gold-light);
    text-transform: uppercase;
    opacity: 0.8;
  }

  .cover-content {
    position: relative;
    z-index: 2;
    padding: 80px 64px 96px;
    max-width: 900px;
  }

  .cover-eyebrow {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.3em;
    color: var(--gold-light);
    text-transform: uppercase;
    margin-bottom: 32px;
    opacity: 0.9;
  }

  .cover-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(52px, 8vw, 96px);
    font-weight: 900;
    line-height: 0.95;
    color: var(--sand);
    margin-bottom: 8px;
  }

  .cover-title em {
    font-style: italic;
    color: var(--gold-light);
  }

  .cover-subtitle {
    font-family: 'Playfair Display', serif;
    font-size: clamp(18px, 3vw, 28px);
    font-weight: 400;
    font-style: italic;
    color: rgba(245,223,168,0.7);
    margin-top: 28px;
    margin-bottom: 48px;
    max-width: 600px;
    line-height: 1.5;
  }

  .cover-line {
    width: 80px;
    height: 2px;
    background: var(--gold);
    margin-bottom: 28px;
  }

  .cover-context {
    font-size: 14px;
    color: rgba(242,232,213,0.5);
    letter-spacing: 0.05em;
    line-height: 1.6;
    max-width: 480px;
  }

  .cover-scroll {
    position: absolute;
    bottom: 40px;
    right: 64px;
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.2em;
    color: rgba(245,223,168,0.3);
    text-transform: uppercase;
    writing-mode: vertical-rl;
  }

  /* ── SECTIONS ── */
  .section {
    padding: 100px 64px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-full {
    padding: 100px 0;
  }

  .section-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 64px;
  }

  /* ── SECTION LABELS ── */
  .section-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .section-label::after {
    content: '';
    display: block;
    height: 1px;
    width: 40px;
    background: var(--gold);
    opacity: 0.4;
  }

  /* ── TYPOGRAPHY ── */
  .heading-xl {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 700;
    line-height: 1.1;
    color: var(--terra-dark);
  }

  .heading-xl em {
    font-style: italic;
    color: var(--gold);
  }

  .heading-lg {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 700;
    line-height: 1.2;
    color: var(--terra-dark);
  }

  .heading-md {
    font-family: 'Playfair Display', serif;
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 700;
    line-height: 1.3;
    color: var(--terra-dark);
  }

  .body-text {
    font-size: 16px;
    line-height: 1.85;
    color: #3A2810;
    max-width: 640px;
  }

  .body-text + .body-text { margin-top: 20px; }

  /* ── ALERT BLOCK ── */
  .alert-block {
    background: var(--terra-dark);
    padding: 56px 64px;
    margin: 0;
    position: relative;
    overflow: hidden;
  }

  .alert-block::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--gold);
  }

  .alert-block-text {
    font-family: 'Playfair Display', serif;
    font-size: clamp(22px, 3vw, 36px);
    font-weight: 700;
    font-style: italic;
    color: var(--sand);
    line-height: 1.4;
    max-width: 700px;
  }

  .alert-block-sub {
    margin-top: 20px;
    font-size: 14px;
    color: rgba(242,232,213,0.55);
    letter-spacing: 0.05em;
    line-height: 1.6;
    max-width: 580px;
  }

  /* ── INCIDENTE BLOCK ── */
  .incident-block {
    background: var(--sand);
    border-left: 4px solid var(--ocean);
    padding: 48px 56px;
    margin: 48px 0;
  }

  .incident-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ocean);
    margin-bottom: 20px;
  }

  .incident-headline {
    font-family: 'Playfair Display', serif;
    font-size: clamp(22px, 3vw, 34px);
    font-weight: 900;
    color: var(--ocean);
    line-height: 1.2;
    margin-bottom: 24px;
  }

  .incident-text {
    font-size: 15px;
    line-height: 1.8;
    color: #2C3E50;
    max-width: 640px;
    margin-bottom: 24px;
  }

  .incident-quote {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-style: italic;
    font-weight: 700;
    color: var(--terra-dark);
    border-top: 1px solid rgba(44,74,110,0.2);
    padding-top: 24px;
    line-height: 1.5;
  }

  /* ── POSITIONING HERO ── */
  .positioning-hero {
    background: var(--gold);
    padding: 80px 64px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .positioning-hero::before {
    content: '"';
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Playfair Display', serif;
    font-size: 320px;
    color: rgba(255,255,255,0.08);
    line-height: 1;
    pointer-events: none;
  }

  .positioning-phrase {
    font-family: 'Playfair Display', serif;
    font-size: clamp(24px, 4vw, 48px);
    font-weight: 900;
    font-style: italic;
    color: var(--terra-dark);
    line-height: 1.3;
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .positioning-sub {
    margin-top: 24px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(92,58,30,0.6);
    position: relative;
    z-index: 1;
  }

  /* ── PILLARS ── */
  .pillars-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2px;
    margin-top: 48px;
    background: var(--sand-dark);
  }

  .pillar {
    background: var(--cream);
    padding: 48px 36px;
    position: relative;
    overflow: hidden;
  }

  .pillar:hover {
    background: var(--smoke);
  }

  .pillar-percent {
    font-family: 'Playfair Display', serif;
    font-size: 80px;
    font-weight: 900;
    line-height: 0.85;
    color: var(--sand-dark);
    margin-bottom: 24px;
    letter-spacing: -4px;
  }

  .pillar-number {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .pillar-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--terra-dark);
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .pillar-desc {
    font-size: 14px;
    line-height: 1.75;
    color: #5C3A1E;
    opacity: 0.85;
  }

  .pillar-accent {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    height: 3px;
  }
  .pillar:nth-child(1) .pillar-accent { background: var(--gold); }
  .pillar:nth-child(2) .pillar-accent { background: var(--ocean); }
  .pillar:nth-child(3) .pillar-accent { background: var(--terra); }

  /* ── POST RECIPE BLOCK ── */
  .post-recipe {
    background: var(--ink);
    padding: 64px;
    margin: 48px 0;
    position: relative;
  }

  .recipe-label {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-bottom: 32px;
  }

  .recipe-title {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--sand);
    margin-bottom: 40px;
    line-height: 1.2;
  }

  .recipe-steps {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .recipe-step {
    border: 1px solid rgba(201,145,58,0.2);
    padding: 28px;
  }

  .step-num {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .step-title {
    font-family: 'Playfair Display', serif;
    font-size: 17px;
    font-weight: 700;
    color: var(--sand);
    margin-bottom: 10px;
  }

  .step-text {
    font-size: 13px;
    line-height: 1.75;
    color: rgba(242,232,213,0.6);
  }

  /* ── CALENDAR ── */
  .calendar-section {
    background: var(--smoke);
  }

  .week-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-top: 40px;
    background: var(--sand-dark);
  }

  .week-day {
    background: var(--cream);
    padding: 24px 16px;
  }

  .day-name {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .day-time {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--terra-dark);
    margin-bottom: 8px;
  }

  .day-format {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ocean);
    margin-bottom: 8px;
  }

  .day-theme {
    font-size: 12px;
    line-height: 1.5;
    color: #5C3A1E;
  }

  /* ── 30-DAY CALENDAR ── */
  .calendar-30 {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2px;
    margin-top: 40px;
    background: var(--sand-dark);
  }

  .cal-day {
    background: var(--cream);
    padding: 20px 16px;
    min-height: 120px;
    position: relative;
  }

  .cal-day:hover { background: var(--smoke); }

  .cal-day-num {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 900;
    color: var(--sand-dark);
    line-height: 1;
    margin-bottom: 8px;
  }

  .cal-day-title {
    font-size: 11px;
    font-weight: 600;
    color: var(--terra-dark);
    line-height: 1.4;
    margin-bottom: 4px;
  }

  .cal-day-format {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .cal-day-pillar {
    position: absolute;
    top: 0; right: 0;
    width: 4px; height: 100%;
  }
  .pillar-1 { background: var(--gold); }
  .pillar-2 { background: var(--ocean); }
  .pillar-3 { background: var(--terra); }

  /* ── VISUAL RULES ── */
  .rules-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    margin-top: 40px;
    background: var(--sand-dark);
  }

  .rules-yes {
    background: var(--cream);
    padding: 48px 40px;
  }

  .rules-no {
    background: var(--terra-dark);
    padding: 48px 40px;
  }

  .rules-header {
    font-family: 'Playfair Display', serif;
    font-size: 36px;
    font-weight: 900;
    margin-bottom: 32px;
  }

  .rules-yes .rules-header { color: var(--gold); }
  .rules-no .rules-header { color: rgba(242,232,213,0.3); }

  .rule-item {
    display: flex;
    gap: 16px;
    margin-bottom: 20px;
    align-items: flex-start;
  }

  .rule-icon {
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    padding-top: 2px;
    flex-shrink: 0;
  }
  .rules-yes .rule-icon { color: var(--gold); }
  .rules-no .rule-icon { color: rgba(242,232,213,0.3); }

  .rule-text {
    font-size: 14px;
    line-height: 1.65;
  }
  .rules-yes .rule-text { color: var(--terra-dark); }
  .rules-no .rule-text { color: rgba(242,232,213,0.55); }

  /* ── PALETTE ── */
  .palette-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2px;
    margin-top: 40px;
    background: var(--sand-dark);
    height: 200px;
  }

  .palette-swatch {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 20px;
  }

  .swatch-1 { background: #8B5E3C; }
  .swatch-2 { background: #C9913A; }
  .swatch-3 { background: #F2E8D5; }
  .swatch-4 { background: #2C4A6E; }

  .swatch-label {
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .swatch-1 .swatch-label,
  .swatch-2 .swatch-label,
  .swatch-4 .swatch-label { color: rgba(255,255,255,0.7); }
  .swatch-3 .swatch-label { color: rgba(92,58,30,0.6); }

  .swatch-pct {
    font-family: 'Playfair Display', serif;
    font-size: 28px;
    font-weight: 900;
  }
  .swatch-1 .swatch-pct,
  .swatch-2 .swatch-pct,
  .swatch-4 .swatch-pct { color: rgba(255,255,255,0.9); }
  .swatch-3 .swatch-pct { color: rgba(92,58,30,0.7); }

  /* ── MONETIZATION TIMELINE ── */
  .timeline {
    position: relative;
    margin-top: 48px;
    padding-left: 40px;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--gold), var(--ocean));
  }

  .timeline-item {
    position: relative;
    margin-bottom: 48px;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--sand-dark);
  }

  .timeline-item:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .timeline-dot {
    position: absolute;
    left: -47px;
    top: 4px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid var(--gold);
    background: var(--cream);
  }

  .timeline-period {
    font-family: 'DM Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 12px;
  }

  .timeline-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 700;
    color: var(--terra-dark);
    margin-bottom: 12px;
  }

  .timeline-text {
    font-size: 14px;
    line-height: 1.8;
    color: #5C3A1E;
    max-width: 560px;
  }

  .price-tag {
    display: inline-block;
    background: var(--sand);
    border: 1px solid var(--gold);
    padding: 4px 12px;
    font-family: 'DM Mono', monospace;
    font-size: 11px;
    color: var(--terra-dark);
    margin: 4px 4px 4px 0;
    letter-spacing: 0.05em;
  }

  /* ── SCRIPTS ── */
  .script-card {
    border: 1px solid var(--sand-dark);
    margin-bottom: 2px;
  }

  .script-header {
    padding: 24px 32px;
    background: var(--sand);
    display: flex;
    align-items: center;
    gap: 20px;
    cursor: pointer;
  }

  .script-num {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 900;
    color: var(--gold);
    opacity: 0.4;
    flex-shrink: 0;
  }

  .script-title {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--terra-dark);
  }

  .script-body {
    padding: 32px 32px 32px 88px;
    background: var(--cream);
  }

  .script-text {
    font-size: 14px;
    line-height: 1.9;
    color: #3A2810;
    background: var(--sand);
    padding: 24px;
    border-left: 3px solid var(--gold);
    font-style: italic;
    white-space: pre-line;
  }

  .script-note {
    margin-top: 16px;
    font-size: 12px;
    color: #8B5E3C;
    font-family: 'DM Mono', monospace;
    letter-spacing: 0.05em;
  }

  /* ── UPLOAD SYSTEM ── */
  .system-row {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 32px;
    align-items: start;
    padding: 32px 0;
    border-bottom: 1px solid var(--sand-dark);
  }

  .system-row:last-child { border-bottom: none; }

  .system-icon {
    font-family: 'Playfair Display', serif;
    font-size: 42px;
    font-weight: 900;
    color: var(--sand-dark);
    line-height: 1;
  }

  .system-title {
    font-family: 'Playfair Display', serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--terra-dark);
    margin-bottom: 8px;
  }

  .system-text {
    font-size: 14px;
    line-height: 1.75;
    color: #5C3A1E;
  }

  .tag {
    display: inline-block;
    background: var(--ocean);
    color: var(--sand);
    font-family: 'DM Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 3px 10px;
    margin-right: 6px;
    margin-top: 8px;
  }

  /* ── CLOSING QUOTE ── */
  .closing {
    background: var(--terra-dark);
    padding: 120px 64px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .closing::before {
    content: 'V';
    position: absolute;
    top: -40px;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'Playfair Display', serif;
    font-size: 400px;
    font-weight: 900;
    color: rgba(255,255,255,0.02);
    pointer-events: none;
    line-height: 1;
  }

  .closing-quote {
    font-family: 'Playfair Display', serif;
